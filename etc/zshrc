zmodload zsh/zprof

NIX_PROFILE=$HOME/.nix-profile

# Powerline
POWERLINE_MODUES="venv,user,ssh,cwd,nix-shell,perms,git,jobs,exit,root"
POWERLINE_PRIORITY="root,user,host,ssh,perms,git-branch,git-status,cwd,hg,jobs,exit,cwd-path"

function powerline_precmd() {
  PS1="$($NIX_PROFILE/bin/powerline-go -jobs ${${(%):%j}:-0} -modules $POWERLINE_MODUES -priority $POWERLINE_PRIORITY -cwd-mode dironly -max-width 60)"
}

function install_powerline_precmd() {
  for s in "${precmd_functions[@]}"; do
    if [ "$s" = "powerline_precmd" ]; then
      return
    fi
  done
  precmd_functions+=(powerline_precmd)
}

if [ "$TERM" != "linux" ] && [ -f "$NIX_PROFILE/bin/powerline-go" ]; then
    install_powerline_precmd
fi

# Bat
export BAT_THEME="Solarized (dark)"

# GPG Config
export GPG_TTY=$(tty)

# Restore Key Binding
bindkey -e

# Zsh Extension
[ -f $NIX_PROFILE/share/zsh-autosuggestions/zsh-autosuggestions.zsh ] && source $NIX_PROFILE/share/zsh-autosuggestions/zsh-autosuggestions.zsh
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=10"
ZSH_AUTOSUGGEST_STRATEGY=(history completion)

# LaTex
export PATH="/Library/TeX/texbin:$PATH"

# Obisidian
[ -d "/Applications/Obsidian.app/Contents/MacOS" ] && export PATH="$PATH:/Applications/Obsidian.app/Contents/MacOS"

# LMStudio
[ -d "$HOME/.lmstudio/bin" ] && export PATH="$PATH:$HOME/.lmstudio/bin"

# Development
[ ! -d $HOME/.pnpm ] && mkdir -p $HOME/.pnpm
export PNPM_HOME=$HOME/.pnpm

export PATH=$NIX_PROFILE/bin:$PATH # Workaround for Nix
[ $(command -v rbenv) ] && eval "$(rbenv init -)"
[ $(command -v go) ] && export PATH=$PATH:$(go env GOPATH)/bin
[ -d $HOME/.npm-global ] && export PATH=$HOME/.npm-global/bin:$PATH # yarn will use this
[ $(command -v pnpm) ] && export PATH=$PATH:$PNPM_HOME
[ $(command -v cargo) ] && export PATH=$HOME/.cargo/bin:$PATH
[ -d $HOME/.local/bin ] && export PATH=$HOME/.local/bin:$PATH

[ -f /opt/homebrew/lib ] && export LIBRARY_PATH=/opt/homebrew/lib:$LIBRARY_PATH
export PKG_CONFIG_PATH=/opt/homebrew/lib/pkgconfig:~/$NIX_PROFILE/pkgconfig:$PKG_CONFIG_PATH

# Godot
[ -f $HOME/Library/Application\ Support/Steam/steamapps/common/Godot\ Engine/Godot.app/Contents/MacOS/Godot ] && alias godot="$HOME/Library/Application\ Support/Steam/steamapps/common/Godot\ Engine/Godot.app/Contents/MacOS/Godot"
[ -f $HOME/Library/Application\ Support/Steam/steamapps/common/Godot\ Engine/Godot.app/Contents/MacOS/Godot ] && alias gut='godot --debug-collisions --path $PWD -d -s addons/gut/gut_cmdln.gd'

# Nix
[ -f $NIX_PROFILE/share/nix-direnv/direnvrc ] && source $NIX_PROFILE/share/nix-direnv/direnvrc
[ -f $NIX_PROFILE/bin/direnv ] && eval "$(direnv hook zsh)"

# Auto Complection
fpath=($NIX_PROFILE/share/zsh/site-functions $fpath)
[ -f $NIX_PROFILE/share/git/contrib/completion/git-completion.zsh ] && zstyle ':completion:*:*:git:*' script $NIX_PROFILE/share/git/contrib/completion/git-completion.zsh

autoload -Uz compinit && compinit
autoload -Uz add-zsh-hook

# pnpm completion
[ $(command -v pnpm) ] && eval "$(pnpm completion zsh)"

# Use "sfw" to protect package managers.
#
# sfw runs an HTTP proxy that scans registry traffic; whatever the command
# spawns inherits that proxy. So only route package-fetching commands through
# sfw and run your own program directly -- otherwise its runtime requests (and
# TLS) are proxied too and break (cert errors / 403).
#
#   Fixed subcommands (uv, cargo) -> bypass the few execution subcommands.
#   Open-ended script names (npm/pnpm/yarn <script>) -> only allow the
#   package-fetching subcommands through sfw; everything else runs direct.
if [ $(command -v sfw) ]; then
  # Python: pip only installs, so the blanket wrapper is safe.
  alias pip='sfw pip'
  alias pip3='sfw pip3'
  alias pipx='sfw pipx'

  uv() { case "$1" in run) command uv "$@" ;; *) sfw uv "$@" ;; esac }
  alias uvx='sfw uvx'

  # Rust: cargo build/check still fetch crates (and run build.rs) -> keep sfw.
  cargo() { case "$1" in run|test|bench) command cargo "$@" ;; *) sfw cargo "$@" ;; esac }

  # JavaScript: scan only install/fetch; `<pm> run`, `<pm> dev`, `<pm> <script>`
  # run direct. dlx/exec download-and-run, so keep them scanned (like uvx).
  npm() { case "$1" in install|i|ci|add|update|dedupe|exec) sfw npm "$@" ;; *) command npm "$@" ;; esac }
  pnpm() { case "$1" in install|i|add|update|up|dedupe|import|fetch|dlx) sfw pnpm "$@" ;; *) command pnpm "$@" ;; esac }
  yarn() { case "$1" in ""|install|add|upgrade|up|import|dedupe|dlx) sfw yarn "$@" ;; *) command yarn "$@" ;; esac }
fi

# Rename tmux window to current directory
if [ -n "$TMUX" ]; then
  function tmux_rename_window() {
     local window_id=$(tmux display-message -t "$TMUX_PANE" -p '#{window_id}')
     [ "$(tmux show-option -wqv -t "$window_id" @renamed)" = "1" ] && return
     local dir=$(git rev-parse --show-toplevel 2>/dev/null || echo "$PWD")
     local window_name=$(basename "$dir")
     tmux rename-window -t "$window_id" "$window_name"
  }

  typeset -g _tmux_ssh_active=

  function tmux_ssh_rename() {
     [[ "$1" =~ '^ssh([[:space:]]|$)' ]] || return
     local window_id=$(tmux display-message -t "$TMUX_PANE" -p '#{window_id}')
     [ "$(tmux show-option -wqv -t "$window_id" @renamed)" = "1" ] && return
     local host=${${(z)1}[-1]}
     host=${host##*@}
     tmux rename-window -t "$window_id" "$host"
     _tmux_ssh_active=1
  }

  function tmux_ssh_restore() {
     [ -n "$_tmux_ssh_active" ] || return
     _tmux_ssh_active=
     tmux_rename_window
  }

  add-zsh-hook chpwd tmux_rename_window
  add-zsh-hook preexec tmux_ssh_rename
  add-zsh-hook precmd tmux_ssh_restore

  tmux_rename_window
fi

# History
setopt HIST_FIND_NO_DUPS
setopt INC_APPEND_HISTORY

# Alias
alias be="bundle exec"
alias rake='noglob rake'

export EDITOR=vim
export GPG_TTY=$(tty)

# Devbox as package manager
eval "$(devbox global shellenv --init-hook)"
